{
  "name": "@web/test-runner-browserstack",
  "type": "module",
  "version": "0.8.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Browserstack launcher for Web Test Runner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modernweb-dev/web.git",
    "directory": "packages/test-runner-browserstack"
  },
  "author": "modern-web",
  "homepage": "https://github.com/modernweb-dev/web/tree/master/packages/test-runner-browserstack",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-transform-types --test --test-force-exit --test-timeout 120000 test-remote/**/*.test.ts",
    "test:watch": "node --experimental-transform-types --test --test-force-exit --test-timeout 120000 test-remote/**/*.test.ts --watch --watch-files src,test"
  },
  "files": [
    "*.d.ts",
    "*.js",
    "dist",
    "src"
  ],
  "keywords": [
    "web",
    "test",
    "runner",
    "testrunner",
    "browserstack",
    "browser",
    "launcher"
  ],
  "dependencies": {
    "@web/test-runner-webdriver": "^0.9.0",
    "browserstack-local": "^1.4.8",
    "internal-ip": "^6.2.0",
    "nanoid": "^3.1.25"
  },
  "devDependencies": {
    "@types/ip": "^1.1.0",
    "@web/dev-server-legacy": "^2.1.0",
    "portfinder": "^1.0.32"
  }
}
