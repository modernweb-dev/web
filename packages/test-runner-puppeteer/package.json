{
  "name": "@web/test-runner-puppeteer",
  "version": "1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Puppeteer browser launcher for Web Test Runner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/modernweb-dev/web.git",
    "directory": "packages/test-runner-puppeteer"
  },
  "author": "modern-web",
  "homepage": "https://github.com/modernweb-dev/web/tree/master/packages/test-runner-puppeteer",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test:node": "node --experimental-strip-types --test --test-force-exit \"test/**/*.test.ts\"",
    "test:watch": "node --experimental-strip-types --test --test-force-exit --watch \"test/**/*.test.ts\""
  },
  "files": [
    "*.d.ts",
    "*.js",
    "*.mjs",
    "dist",
    "src"
  ],
  "keywords": [
    "web",
    "test",
    "runner",
    "testrunner",
    "puppeteer",
    "browser",
    "launcher"
  ],
  "dependencies": {
    "@web/test-runner-chrome": "^1.0.0",
    "@web/test-runner-core": "^1.0.0",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@web/test-runner-mocha": "^1.0.0",
    "puppeteer-core": "^24.0.0"
  }
}
