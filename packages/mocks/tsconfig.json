{
  "extends": "../../tsconfig.new.json",
  "compilerOptions": {
    "outDir": "./dist-types",
    "rootDir": "."
  },
  "include": [
    "**/*.js",
    "**/*.ts"
  ],
  "exclude": [
    "dist-types",
    "test-browser"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node",
      "rewriteRelativeImportExtensions": false
    }
  }
}
